# Fortunia integration env vars for Kraken

# Fortunia API connection
FORTUNA_API_URL=http://localhost:8000
FORTUNA_API_KEY=<copy from Fortunia's INTERNAL_API_KEY>

# OpenClaw paths (if using standalone)
OPENCLAW_CONFIG=~/.openclaw/openclaw.json
OPENCLAW_WORKSPACE=~/.openclaw/workspace
OPENCLAW_WORKSPACE_FORTUNIA=~/.openclaw/workspace-fortunia
